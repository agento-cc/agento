# Agento — Secrets Configuration
# Copy this file to ../secrets.env (parent directory) and fill in the values.
# IMPORTANT: Never commit secrets.env to git!

# Jira API (module config: CONFIG__{MODULE}__{FIELD})
CONFIG__JIRA__JIRA_HOST=https://your-instance.atlassian.net
CONFIG__JIRA__JIRA_USER=
CONFIG__JIRA__JIRA_TOKEN=

# SMTP (for email_send tool)
CONFIG__CORE__SMTP_HOST=
CONFIG__CORE__SMTP_PORT=587
CONFIG__CORE__SMTP_USER=
CONFIG__CORE__SMTP_PASS=
CONFIG__CORE__SMTP_FROM=

# Database credentials — add per-system based on your module.json tool fields.
# After running: bin/agento module:add my-app --tool mysql:mysql_myapp_prod:"My DB"
# Add these vars using CONFIG__MODULE__TOOLS__TOOL__FIELD format:
#
# CONFIG__MY_APP__TOOLS__MYSQL_MYAPP_PROD__HOST=10.0.0.1
# CONFIG__MY_APP__TOOLS__MYSQL_MYAPP_PROD__PORT=3306
# CONFIG__MY_APP__TOOLS__MYSQL_MYAPP_PROD__USER=reader
# CONFIG__MY_APP__TOOLS__MYSQL_MYAPP_PROD__PASS=secret
# CONFIG__MY_APP__TOOLS__MYSQL_MYAPP_PROD__DATABASE=mydb
