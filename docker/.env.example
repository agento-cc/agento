# Claude Code Docker Environment
# Only needed for --api mode (pay-per-token)
# Default OAuth mode uses your Claude Pro/Max subscription - no config needed

# Dev repo only: select the dev compose file (mounts src/agento directly).
# Downstream projects should omit this and use the managed docker-compose.yml.
COMPOSE_FILE=docker-compose.dev.yml

# API Key (only for: ./run-claude.sh --api "prompt")
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Set to 1 to skip Claude CLI execution (consumer will dequeue jobs but not run claude -p)
DISABLE_LLM=0
AGENTO_CONSUMER_MAX_WORKERS=1
AGENTO_CONSUMER_POLL_INTERVAL=5
AGENTO_JOB_TIMEOUT_SECONDS=1200 # 20min