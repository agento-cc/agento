{
  "timezone": "UTC",
  "sql_timeout_seconds": 300,
  "client_connection_pool_max_per_tool": 10,
  "server_concurrency_budget": 10,
  "smtp_port": 587,
  "allow_subdomains": true,
  "allow_http": false,
  "toolbox/url": "http://toolbox:3001",
  "toolbox/file_manager/allowed_extensions": ".pdf,.xlsx,.xls,.csv,.txt,.md,.json,.xml,.html,.png,.jpg,.jpeg,.gif,.svg,.webp",
  "toolbox/file_manager/max_file_size": 524288000,
  "toolbox/result_offload/threshold": 20000,
  "toolbox/result_offload/sample_rows": 5,
  "toolbox/result_offload/text_preview_chars": 200,
  "tools/email_send/is_enabled": "1",
  "tools/browser/is_enabled": "1",
  "tools/schedule_followup/is_enabled": "1"
}
