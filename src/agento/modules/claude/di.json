{
  "runtimes": [
    {"provider": "claude", "class": "src.runner.TokenClaudeRunner"}
  ],
  "auth_strategies": [
    {"provider": "claude", "class": "src.auth.ClaudeAuthStrategy"}
  ],
  "config_writers": [
    {"provider": "claude", "class": "src.config.ClaudeConfigWriter"}
  ],
  "cli_invokers": [
    {"provider": "claude", "class": "src.cli.ClaudeCliInvoker"}
  ],
  "transcript_readers": [
    {"provider": "claude", "class": "src.transcript_reader.ClaudeTranscriptReader"}
  ],
  "sandbox_packages": [
    {
      "provider": "claude",
      "manager": "npm",
      "package": "@anthropic-ai/claude-code",
      "binary": "claude",
      "version_env_key": "CLAUDE_CODE_VERSION",
      "default_range": "~2.1.142"
    }
  ]
}
