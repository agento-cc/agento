{
  "provider": {
    "type": "select",
    "label": "Agent provider",
    "description": "Which agent CLI this view runs. Must match a registered provider module.",
    "options": [
      {"value": "claude", "label": "Claude Code"},
      {"value": "codex", "label": "OpenAI Codex"}
    ]
  },
  "model": {
    "type": "string",
    "label": "Agent model",
    "description": "Model ID passed to the provider CLI via --model. Claude: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5 (aliases: opus, sonnet, haiku). Codex: gpt-5.4 | gpt-5.4-mini."
  },
  "scheduling/priority":          {"type": "integer",  "label": "Job priority (0-100)"},
  "mcp/servers":                  {"type": "textarea", "label": "Additional MCP servers (JSON dict; merged on top of auto-injected toolbox entry)"},
  "instructions/agents_md":       {"type": "textarea", "label": "AGENTS.md content (overrides theme)"},
  "instructions/soul_md":         {"type": "textarea", "label": "SOUL.md content (overrides theme)"},
  "identity/ssh_private_key": {
    "type": "obscure",
    "label": "SSH private key (id_rsa, encrypted at rest)",
    "showInDefault": true,
    "showInWorkspace": true,
    "showInAgentView": true
  },
  "identity/ssh_public_key": {
    "type": "textarea",
    "label": "SSH public key (id_rsa.pub)",
    "showInDefault": true,
    "showInWorkspace": true,
    "showInAgentView": true
  },
  "identity/ssh_config": {
    "type": "textarea",
    "label": "Optional ~/.ssh/config contents (Host/IdentityFile directives)",
    "showInDefault": true,
    "showInWorkspace": true,
    "showInAgentView": true
  },
  "identity/ssh_known_hosts": {
    "type": "textarea",
    "label": "Optional ~/.ssh/known_hosts contents (prepopulated trust)",
    "showInDefault": true,
    "showInWorkspace": true,
    "showInAgentView": true
  }
}
