{
  "runtimes": [
    {"provider": "codex", "class": "src.runner.TokenCodexRunner"}
  ],
  "auth_strategies": [
    {"provider": "codex", "class": "src.auth.CodexAuthStrategy"}
  ],
  "config_writers": [
    {"provider": "codex", "class": "src.config.CodexConfigWriter"}
  ],
  "cli_invokers": [
    {"provider": "codex", "class": "src.cli.CodexCliInvoker"}
  ],
  "transcript_readers": [
    {"provider": "codex", "class": "src.transcript_reader.CodexTranscriptReader"}
  ],
  "sandbox_packages": [
    {
      "provider": "codex",
      "manager": "npm",
      "package": "@openai/codex",
      "binary": "codex",
      "version_env_key": "CODEX_VERSION",
      "default_range": "0.142.5"
    }
  ]
}
