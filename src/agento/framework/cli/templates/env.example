COMPOSE_PROJECT_NAME={compose_project_name}
AGENTO_VERSION={agento_version}
MYSQL_ROOT_PASSWORD={mysql_root_password}
MYSQL_PASSWORD={mysql_password}
MYSQL_PORT={mysql_port}
TZ={timezone}
# Container `agent` user UID/GID — pinned at install/upgrade so bind-mounted
# host paths are writable by the unprivileged in-container user. Override
# only if you know what you're doing (e.g. multi-user shared deployments).
HOST_UID={host_uid}
HOST_GID={host_gid}
# Agent CLI version pins are appended below by `agento install`. Sourced from
# each agent module's `sandbox_packages` declaration in di.json — soft-pinned
# (tilde) so patch upgrades flow through but a minor jump requires a
# deliberate choice. Bump here and rebuild (agento upgrade --no-restart &&
# docker compose build sandbox) to test a new upstream release without
# waiting for an agento release.
{sandbox_package_pins}# Set to 1 to disable LLM API calls (mocks agent output, for testing)
DISABLE_LLM=0
