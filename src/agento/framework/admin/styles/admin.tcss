Screen {
    padding: 1;
}

.panel {
    border: round $primary;
    padding: 1 2;
    margin: 0 1 1 0;
    height: auto;
}

.panel-title {
    text-style: bold;
    color: $text;
    margin-bottom: 1;
}

#dashboard-top {
    height: auto;
    max-height: 12;
}

#health-panel {
    width: 1fr;
}

#system-panel {
    width: 1fr;
}

#jobs-panel {
    height: auto;
    max-height: 14;
}

#dashboard-bottom {
    height: auto;
    max-height: 12;
}

#tokens-panel {
    width: 1fr;
}

#agents-panel {
    width: 1fr;
}

#recent-jobs-table {
    height: auto;
    max-height: 8;
}

#placeholder {
    padding: 2 4;
    text-align: center;
    text-style: italic;
    color: $text-muted;
}

DataTable {
    height: auto;
}

#jobs-filter-bar {
    height: auto;
    max-height: 3;
    margin-bottom: 1;
}

#jobs-search {
    width: 1fr;
}

#jobs-status-label {
    width: auto;
    min-width: 20;
    padding: 1 2;
    text-style: bold;
}

#jobs-table {
    height: auto;
}

#jobs-table-panel {
    height: 1fr;
}

#job-detail-scroll {
    width: 80%;
    height: 80%;
    margin: 2 4;
}

#replay-confirm {
    width: 50;
    height: auto;
    margin: 4 auto;
}

/* Config screen layout */
#config-top {
    height: auto;
    padding: 0 1;
}

#scope-bar {
    height: auto;
}

#scope-bar Select {
    width: 1fr;
    margin: 0 1 0 0;
}

#config-main {
    height: 1fr;
}

#module-tree {
    width: 25;
    border: solid $secondary;
    padding: 0 1;
}

#field-table-container {
    width: 1fr;
}

#field-search {
    margin: 0 0 1 0;
}

#field-table {
    width: 1fr;
}

#field-detail {
    height: auto;
    min-height: 5;
    max-height: 8;
    border: solid $secondary;
    padding: 0 1;
}

/* Modal screens */
#editor-dialog {
    width: 60;
    height: auto;
    border: thick $primary;
    padding: 1 2;
    background: $surface;
}

#editor-buttons {
    height: auto;
    margin-top: 1;
}

#editor-buttons Button {
    margin: 0 1 0 0;
}

ModalScreen {
    align: center middle;
}
